---
import type { CatalogProvider } from '../types/configmap';

interface Props {
  provider: CatalogProvider;
}

const { provider } = Astro.props;
---

<button
  type="button"
  class="provider-card"
  data-provider-id={provider.id}
  aria-pressed="false"
>
  <h3>{provider.name}</h3>
  <div class="provider-id">{provider.id}</div>
  <p class="provider-desc">{provider.description}</p>
  <div class="provider-meta">
    <span class="chip">{provider.benchmarkCount} benchmarks</span>
    {provider.categories.slice(0, 3).map((cat) => (
      <span class="chip">{cat}</span>
    ))}
  </div>
</button>
