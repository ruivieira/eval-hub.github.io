# Adapter execution sequence
exec: Execution {
  shape: sequence_diagram
  a: Adapter
  f: Framework
  c: Callbacks
  s: Sidecar
  r: OCI Registry
  m: MLflow

  a -> c: report_status(RUNNING)
  c -> s: POST /events
  a -> f: Run Benchmark
  f -> a: Raw Results
  a -> a: Parse Results
  a -> c: create_oci_artifact()
  c -> r: Push OCI Artifact
  r -> c: digest
  a -> c: report_results()
  c -> s: POST /events
  c -> m: log metrics
}
