# EvalHub system architecture (getting-started/overview)
direction: down

*.style.shadow: true
*.style.stroke: "#404040"
*.style.fill: "#f5f5f5"
*.style.border-radius: 4

clients: Clients {
  style.fill: "#ddd"
  direction: right
  sdk: "Python SDK\nevalhub.client"
  rest: "REST API\ncurl / HTTP"
}

evalhub: "EvalHub Server" {
  style.fill: "#e8e8e8"
  direction: right

  api: "REST API\n/api/v1"
  orch: "Job Orchestrator"
  prov: "Provider Registry"
  provconfig: "Config Loader\nproviders/*.yaml"
  coll: "Collection Registry"
  collconfig: "Config Loader\ncollectionss/*.yaml"

  api -> orch
  api -> prov
  provconfig -> prov
  api -> coll
  collconfig -> coll
}

servicestorage: Service Storage {
  style.fill: "#e8e8e8"
  style.shadow: true
  db: "PostgreSQL / SQLite"
}

runtimes: "Kubernetes / OpenShift" {
  style.fill: "#e8e8e8"
  direction: right

  cm: "ConfigMap\n/meta/job.json"
  pod: "Evaluation Job Pod" {
    adapter: "Adapter Container\nFrameworkAdapter"
    sidecar: "Sidecar\nEvent Forwarder"
  }
  local: "Local Runtime" {
    style.stroke-dash: 3
  }
}

bottom: "" {
  style.fill: transparent
  style.stroke: transparent
  style.shadow: false
  direction: right

  userstorage: User Storage {
    style.fill: "#e8e8e8"
    style.shadow: true
    oci: "OCI Registry"
  }

  external: "External Services" {
    style.fill: "#ddd"
    style.shadow: true
    model: "Model Endpoint\nvLLM, OpenAI, TGI"
    mlflow: "MLflow"
  }
}

clients -> evalhub.api: REST {style.border-radius: 8}

evalhub.orch -> runtimes.cm: creates {style.border-radius: 8}
evalhub.orch -> runtimes.pod: "creates Job" {style.border-radius: 8}
evalhub.orch -> runtimes.local: spawns {style.border-radius: 8; style.stroke-dash: 3}
evalhub.orch -> bottom.external.mlflow: "create experiment" {style.border-radius: 8}
evalhub.api -> servicestorage.db: {style.border-radius: 8}

runtimes.cm -> runtimes.pod.adapter: mounted {style.border-radius: 8}
runtimes.pod.adapter -> runtimes.pod.sidecar: callbacks {style.border-radius: 8}
runtimes.pod.adapter -> bottom.external.model: inference {style.border-radius: 8}
runtimes.pod.sidecar -> bottom.external.mlflow: "log metrics" {style.border-radius: 8}
runtimes.pod.sidecar -> bottom.userstorage.oci: "push artifacts" {style.border-radius: 8}
runtimes.pod.sidecar -> evalhub.api: "POST /events" {
  style.stroke-dash: 3
  style.border-radius: 8
}
