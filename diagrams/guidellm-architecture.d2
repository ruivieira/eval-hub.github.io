# GuideLLM adapter architecture
direction: down

*.style.border-radius: 4

evalhub: EvalHub Server {
  direction: right
  api: REST API
  orch: Job Orchestrator
}

k8s: "Kubernetes / OpenShift" {
  direction: right
  cm: "ConfigMap\n/meta/job.json"
  pod: GuideLLM Job Pod {
    adapter: GuideLLM Adapter {
      load: "1. Load JobSpec"
      run: "2. Run GuideLLM"
      parse: "3. Parse metrics"
      report: "4. Report results"

      load -> run
      run -> parse
      parse -> report
    }
    sidecar: Sidecar
  }
}

external: External {
  direction: right
  model: Model Endpoint
  oci: OCI Registry
  mlflow: MLflow
}

evalhub.orch -> k8s.cm: creates
evalhub.orch -> k8s.pod: creates Job
k8s.cm -> k8s.pod.adapter: mounted
k8s.pod.adapter.run -> external.model: benchmark requests
k8s.pod.adapter.report -> k8s.pod.sidecar: callbacks
k8s.pod.sidecar -> evalhub.api: "POST /events" {
  style.stroke-dash: 3
}
k8s.pod.adapter -> external.oci: push artifacts
k8s.pod.adapter -> external.mlflow: log metrics
