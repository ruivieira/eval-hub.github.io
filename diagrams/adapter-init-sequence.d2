# Adapter initialisation sequence
init: Initialisation {
  shape: sequence_diagram
  k: Kubernetes
  a: Adapter
  fs: File System
  env: Environment

  k -> a: Start container
  k -> a: "Mount ConfigMap (/meta/job.json)"
  k -> env: "Set JOB_ID, EVALHUB_URL"
  a -> env: Load AdapterSettings
  a -> fs: Read JobSpec
  fs -> a: "JobSpec (provider, benchmark, model)"
  a -> a: Create DefaultCallbacks
}
